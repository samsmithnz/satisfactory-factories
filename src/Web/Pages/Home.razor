        {
            factory.Hidden = false;
            StateHasChanged();
            await Task.Delay(50);
        }
        await JSRuntime.InvokeVoidAsync("scrollToElement", $"factory-{factory.Id}");
    }

    public void Dispose()
    {
        AppState.OnChange -= StateHasChanged;
    }
}
