    private async Task OnPartSelected(FactoryItem product, Factory factory, string partId)
    {
        Console.WriteLine($"Home: OnPartSelected start — factory='{factory.Name}', partId='{partId}', product.Id was='{product.Id}', renderCount={_renderCount}");

        product.Id = partId;

        if (!string.IsNullOrEmpty(partId))
        {
            string defaultRecipe = GameDataService.GetDefaultRecipeForPart(partId);
            List<Recipe> recipes = GameDataService.GetRecipesForPart(partId);
            product.Recipe = !string.IsNullOrEmpty(defaultRecipe) && recipes.Count > 0
                ? defaultRecipe
                : (recipes.Count > 0 ? recipes[0].Id : string.Empty);
            Console.WriteLine($"Home: OnPartSelected — set recipe='{product.Recipe}', {recipes.Count} recipes available");
        }
        else
        {
            product.Recipe = string.Empty;
        }

        Console.WriteLine($"Home: OnPartSelected — awaiting Task.Yield() to allow first render pass (renderCount={_renderCount})");

        // Yield to let Blazor render the product-row structural changes (icon, recipe/amount
        // controls) before RecalculateAll triggers the satisfaction-section and raw-resources
        // changes.  Running both structural groups in the same render pass causes Blazor's
        // DOM reconciliation to call removeChild on a null parent reference.
        await Task.Yield();

        Console.WriteLine($"Home: OnPartSelected — resumed after Task.Yield(), renderCount={_renderCount}, calling RecalculateAll");
        RecalculateAll();
        Console.WriteLine($"Home: OnPartSelected — complete, renderCount={_renderCount}");
    }

