    private List<StatRawResource> GetTotalRawResources()
    {
        Dictionary<string, double> totals = new Dictionary<string, double>();
        foreach (Factory factory in _factories)
        {
            foreach (KeyValuePair<string, WorldRawResource> kv in factory.RawResources)
            {
                totals[kv.Key] = totals.GetValueOrDefault(kv.Key) + kv.Value.Amount;
            }
        }

        return totals
            .Select(kv => new StatRawResource(kv.Key, kv.Value))
            .OrderBy(r => GameDataService.GetPartDisplayName(r.Id))
            .ToList();
    }

    private List<StatBuilding> GetTotalBuildings()
    {
        Dictionary<string, double> totals = new Dictionary<string, double>();
        foreach (Factory factory in _factories)
        {
            foreach (KeyValuePair<string, BuildingRequirement> kv in factory.BuildingRequirements)
            {
                totals[kv.Key] = totals.GetValueOrDefault(kv.Key) + kv.Value.Amount;
            }
        }

        return totals
            .Select(kv => new StatBuilding(kv.Key, kv.Value))
            .OrderBy(b => b.Name)
            .ToList();
    }

    private (double consumed, double produced, double diff) GetTotalPower()
    {
        double consumed = _factories.Sum(f => f.Power.Consumed);
        double produced = _factories.Sum(f => f.Power.Produced);
        return (consumed, produced, produced - consumed);
    }

    private List<StatPartDifference> GetProductSurplusDeficit()
    {
        Dictionary<string, double> totals = new Dictionary<string, double>();
        foreach (Factory factory in _factories)
        {
            foreach (KeyValuePair<string, PartMetrics> kv in factory.Parts)
            {
                if (kv.Value.IsRaw) continue;
                totals[kv.Key] = totals.GetValueOrDefault(kv.Key) + kv.Value.AmountRemaining;
            }
        }

        return totals
            .Where(kv => kv.Value != 0)
            .Select(kv => new StatPartDifference(kv.Key, kv.Value))
            .OrderBy(p => GameDataService.GetPartDisplayName(p.Id))
            .ToList();
    }

    private List<StatProducedItem> GetProducedItems()
    {
        Dictionary<string, double> totals = new Dictionary<string, double>();
        foreach (Factory factory in _factories)
        {
            foreach (KeyValuePair<string, PartMetrics> kv in factory.Parts)
            {
                if (kv.Value.IsRaw) continue;
                if (kv.Value.AmountSupplied <= 0) continue;
                totals[kv.Key] = totals.GetValueOrDefault(kv.Key) + kv.Value.AmountSupplied;
            }
        }

        return totals
            .Select(kv => new StatProducedItem(kv.Key, kv.Value))
            .OrderBy(p => GameDataService.GetPartDisplayName(p.Id))
            .ToList();
    }

    private List<SummaryImport> GetSummaryImports(Factory factory)
    {
        Dictionary<string, double> totals = new Dictionary<string, double>();
        foreach (FactoryInput input in factory.Inputs)
        {
            if (!string.IsNullOrEmpty(input.OutputPart) && input.Amount > 0)
            {
                totals[input.OutputPart] = totals.GetValueOrDefault(input.OutputPart) + input.Amount;
            }
        }
        foreach (KeyValuePair<string, WorldRawResource> kv in factory.RawResources)
        {
            if (kv.Value.Amount > 0)
            {
                totals[kv.Key] = totals.GetValueOrDefault(kv.Key) + kv.Value.Amount;
            }
        }
        return totals
            .Select(kv => new SummaryImport(kv.Key, kv.Value))
            .OrderBy(i => GameDataService.GetPartDisplayName(i.PartId))
            .ToList();
    }

    private List<SummaryExport> GetSummaryExports(Factory factory)
    {
        if (factory.Dependencies?.Requests == null)
        {
            return new List<SummaryExport>();
        }

        Dictionary<string, double> totals = new Dictionary<string, double>();
        foreach (KeyValuePair<string, List<FactoryDependencyRequest>> req in factory.Dependencies.Requests)
        {
            foreach (FactoryDependencyRequest dr in req.Value)
            {
                totals[dr.Part] = totals.GetValueOrDefault(dr.Part) + dr.Amount;
            }
        }
        return totals
            .Select(kv => new SummaryExport(kv.Key, kv.Value))
            .OrderBy(e => GameDataService.GetPartDisplayName(e.PartId))
            .ToList();
    }

