        return pm;
    }

    private void SatisfyImport(Factory factory, FactoryInput input)
    {
        if (string.IsNullOrEmpty(input.OutputPart)) return;

        int inputIndex = factory.Inputs.IndexOf(input);

        double totalOtherImported = factory.Inputs
            .Select((imp, idx) => new { imp, idx })
            .Where(x => x.idx != inputIndex && x.imp.OutputPart == input.OutputPart)
            .Sum(x => x.imp.Amount);

        if (!factory.Parts.TryGetValue(input.OutputPart, out PartMetrics? partData)) return;

        double difference = partData.AmountRequired - partData.AmountSuppliedViaProduction - totalOtherImported;
        input.Amount = difference > 0 ? difference : 0;
        RecalculateAll();
    }

    private async Task NavigateToFactory(int? factoryId)
