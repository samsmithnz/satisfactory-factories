    private static string GetFuelDisplayName(string displayName)
    {
        int openParenIndex = displayName.IndexOf('(');
        int closeParenIndex = displayName.IndexOf(')');
        if (openParenIndex >= 0 && closeParenIndex > openParenIndex)
        {
            return displayName.Substring(openParenIndex + 1, closeParenIndex - openParenIndex - 1);
        }

        return displayName;
    }

