@page "/"
@using Web.Models
@using Web.Models.Factory
@using Web.Services
@using Web.Services.FactoryManagement
@inject IAppStateService AppState
@inject GameDataService GameDataService
@inject IFactoryCalculationService FactoryCalcService
@inject NavigationManager NavManager
@inject LoadingService LoadingService
@inject DemoPlansService DemoPlansService
@inject IJSRuntime JSRuntime
@inject IToastService ToastService
@implements IDisposable

<PageTitle>Satisfactory Factories - Production Planner</PageTitle>

<Introduction Source="planner" ForceShow="@_showIntroDialog" OnClosed="HandleIntroClosed" />

<div class="planner-page">
    @if (!_isLoaded)
    {
        <div class="loading-container">
            <div class="loading-message">Loading Planner...</div>
        </div>
    }
    else
    {
        <div class="planner-container">
            <div class="two-pane-container">
                <!-- Sidebar (Desktop only) -->
                <div class="sticky-sidebar d-none d-lg-flex">
                    <div class="sidebar-content">
                        <h3>Factories</h3>
                        @if (_factories.Count == 0)
                        {
                            <p class="text-grey">No factories yet. Create one to get started!</p>
                        }
                        else
                        {
                            <ul class="factory-list">
                                @foreach (Factory factory in _factories)
                                {
                                    <li><a href="#factory-@factory.Id">@factory.Name</a></li>
                                }
                            </ul>
                        }
                        <div class="sidebar-actions mt-4">
                            <button class="btn btn-primary" @onclick="CreateFactory">
                                <i class="fas fa-plus"></i> Add Factory
                            </button>
                            <TemplatesDialog OnTemplateLoaded="HandleTemplateLoaded" />
                            <div class="d-flex gap-2 mt-2">
                                <button class="btn btn-info flex-1" @onclick="ShowIntro" title="Show introduction">
                                    <i class="fas fa-info-circle"></i> Show Intro
                                </button>
                                <button class="btn btn-warning flex-1"
                                        disabled="@(_factories.Count == 0 || _disableRecalc)"
                                        @onclick="ForceRecalculate"
                                        title="Force recalculate all factories">
                                    <i class="fas fa-calculator-alt"></i> Recalculate
                                </button>
                            </div>
                            @if (_factories.Count > 0)
                            {
                                <div class="d-flex gap-2 mt-2">
                                    <button class="btn btn-secondary flex-1" @onclick="HideAllFactories" title="Collapse all factories">
                                        <i class="fas fa-compress-alt"></i> Hide All
                                    </button>
                                    <button class="btn btn-secondary flex-1" @onclick="ShowAllFactories" title="Expand all factories">
                                        <i class="fas fa-expand-alt"></i> Expand All
                                    </button>
                                </div>
                                <div class="d-flex gap-2 mt-2">
                                    <button class="btn btn-secondary flex-1" @onclick="CopyPlanToClipboard" title="Copy plan to clipboard">
                                        <i class="fas fa-copy"></i> Copy Plan
                                    </button>
                                    <button class="btn btn-secondary flex-1" @onclick="PastePlanFromClipboard" title="Paste plan from clipboard">
                                        <i class="fas fa-clipboard"></i> Paste Plan
                                    </button>
                                </div>
                                <div class="d-flex gap-2 mt-2">
                                    <button class="btn btn-secondary flex-1" @onclick="ClearAll">
                                        <i class="fas fa-trash"></i> Clear All
                                    </button>
                                    <ShareButton />
                                </div>
                            }
                        </div>
                    </div>
                </div>

                <!-- Main Content Area -->
                <div class="main-content">
                    @if (_factories.Count == 0)
                    {
                        <div class="welcome-message">
                            <h2>Welcome to Satisfactory Factories!</h2>
                            <p>This is a production planning tool for the game Satisfactory.</p>
                            <p>Get started by creating your first factory or load a demo plan.</p>
                            <div class="welcome-actions">
                                <button class="btn btn-primary btn-lg" @onclick="CreateFactory">
                                    <i class="fas fa-plus"></i> Create Your First Factory
                                </button>
                                <TemplatesDialog OnTemplateLoaded="HandleTemplateLoaded" />
                            </div>
                        </div>
                    }
                    else
                    {
                        <!-- Statistics Section -->
                        <div class="statistics-panel @(_statisticsHidden ? "statistics-collapsed" : "")">
                            <div class="statistics-header">
                                <h4 class="statistics-title">
                                    <i class="fas fa-list mr-2"></i>Statistics
                                </h4>
                                <button class="btn btn-sm btn-outline-secondary" @onclick="ToggleStatistics">
                                    <i class="fas @(_statisticsHidden ? "fa-eye" : "fa-eye-slash") mr-1"></i>
                                    @(_statisticsHidden ? "Show" : "Hide")
                                </button>
                            </div>
                            @if (!_statisticsHidden)
                            {
                                <div class="statistics-body">
                                    <!-- Raw Resources -->
                                    <div class="statistics-section">
                                        <h5 class="text-h5"><i class="fas fa-globe mr-2"></i>Raw Resources</h5>
                                        @{ List<StatRawResource> rawResources = GetTotalRawResources(); }
                                        @if (rawResources.Count > 0)
                                        {
                                            <div class="d-flex flex-wrap gap-2">
                                                @foreach (StatRawResource res in rawResources)
                                                {
                                                    <span class="sf-chip small cyan">
                                                        <GameAsset Subject="@res.Id" Type="item" Height="24" Width="24" />
                                                        <span class="ml-2"><b>@GameDataService.GetPartDisplayName(res.Id)</b>: @FormatNumber(res.TotalAmount)/min</span>
                                                    </span>
                                                }
                                            </div>
                                        }
                                        else
                                        {
                                            <p class="text-grey">Awaiting Resource Consumption</p>
                                        }
                                    </div>
                                    <hr class="factory-divider" />
                                    <!-- Building Summary -->
                                    <div class="statistics-section">
                                        <h5 class="text-h5"><i class="fas fa-building mr-2"></i>Building Summary</h5>
                                        @{ List<StatBuilding> buildings = GetTotalBuildings(); }
                                        @if (buildings.Count > 0)
                                        {
                                            <div class="d-flex flex-wrap gap-2">
                                                @foreach (StatBuilding bldg in buildings)
                                                {
                                                    <span class="sf-chip small orange">
                                                        <GameAsset Subject="@bldg.Name" Type="building" Height="24" Width="24" />
                                                        <span class="ml-1"><b>@GameDataService.GetBuildingDisplayName(bldg.Name)</b>: @FormatNumber(bldg.TotalAmount)x</span>
                                                    </span>
                                                }
                                            </div>
                                        }
                                        else
                                        {
                                            <p class="text-grey">Awaiting Building Construction</p>
                                        }
                                    </div>
                                    <hr class="factory-divider" />
                                    <!-- Power -->
                                    <div class="statistics-section">
                                        <h5 class="text-h5"><i class="fas fa-power-off mr-2"></i>Power Consumption and Generation</h5>
                                        @{ (double consumed, double produced, double diff) = GetTotalPower(); }
                                        <span class="sf-chip small yellow"><i class="fas fa-bolt mr-1"></i><i class="fas fa-minus mr-1"></i><span>@FormatPower(consumed) consumed</span></span>
                                        <span class="sf-chip small yellow"><i class="fas fa-bolt mr-1"></i><i class="fas fa-plus mr-1"></i><span>@FormatPower(produced) generated</span></span>
                                        <span class="sf-chip small @(diff > 0 ? "green" : diff < 0 ? "red" : "")"><i class="fas fa-plug mr-2"></i><span>@FormatPower(diff) difference</span></span>
                                    </div>
                                    <hr class="factory-divider" />
                                    <!-- Product Surplus & Deficit -->
                                    <div class="statistics-section">
                                        <h5 class="text-h5"><i class="fas fa-warehouse mr-2"></i>Product Surplus &amp; Deficit</h5>
                                        @{ List<StatPartDifference> diffs = GetProductSurplusDeficit(); }
                                        @if (diffs.Count > 0)
                                        {
                                            <div class="d-flex flex-wrap gap-2">
                                                @foreach (StatPartDifference pd in diffs)
                                                {
                                                    <span class="sf-chip small @(pd.AmountRemaining > 0 ? "green" : "red")">
                                                        <GameAsset Subject="@pd.Id" Type="item" Height="24" Width="24" />
                                                        <span class="ml-2"><b>@GameDataService.GetPartDisplayName(pd.Id)</b>: @FormatNumber(pd.AmountRemaining)/min</span>
                                                    </span>
                                                }
                                            </div>
                                        }
                                        else
                                        {
                                            <p class="text-grey">No Product Surplus or Deficit</p>
                                        }
                                    </div>
                                    <hr class="factory-divider" />
                                    <!-- Produced Items toggle -->
                                    <div class="text-center">
                                        <button class="btn btn-sm btn-outline-secondary" @onclick="ToggleStatisticsProducts">
                                            <i class="fas @(_statisticsProductsHidden ? "fa-eye" : "fa-eye-slash") mr-1"></i>
                                            @(_statisticsProductsHidden ? "Show all Products" : "Hide all Products")
                                        </button>
                                    </div>
                                    @if (!_statisticsProductsHidden)
                                    {
                                        <hr class="factory-divider" />
                                        <!-- Produced Items -->
                                        <div class="statistics-section">
                                            <h5 class="text-h5"><i class="fas fa-conveyor-belt-alt mr-2"></i>Produced Items</h5>
                                            @{ List<StatProducedItem> producedItems = GetProducedItems(); }
                                            @if (producedItems.Count > 0)
                                            {
                                                <div class="d-flex flex-wrap gap-2">
                                                    @foreach (StatProducedItem item in producedItems)
                                                    {
                                                        <span class="sf-chip small blue">
                                                            <GameAsset Subject="@item.Id" Type="item" Height="24" Width="24" />
                                                            <span class="ml-2"><b>@GameDataService.GetPartDisplayName(item.Id)</b>: @FormatNumber(item.AmountSupplied)/min</span>
                                                        </span>
                                                    }
                                                </div>
                                            }
                                            else
                                            {
                                                <p class="text-grey">Awaiting Production</p>
                                            }
                                        </div>
                                    }
                                </div>
                            }
                        </div>

                        <!-- Factories Summary -->
                        <div class="statistics-panel @(_summarySectionHidden ? "statistics-collapsed" : "")">
                            <div class="statistics-header">
                                <h4 class="statistics-title">
                                    <i class="fas fa-list mr-2"></i>Factories Summary
                                </h4>
                                <button class="btn btn-sm btn-outline-secondary" @onclick="ToggleSummary">
                                    <i class="fas @(_summarySectionHidden ? "fa-eye" : "fa-eye-slash") mr-1"></i>
                                    @(_summarySectionHidden ? "Show" : "Hide")
                                </button>
                            </div>
                            @if (!_summarySectionHidden)
                            {
                                <div class="factories-summary-table-wrapper">
                                    <table class="factories-summary-table">
                                        <thead>
                                            <tr>
                                                <th><i class="fas fa-industry mr-1"></i> Factory Name</th>
                                                <th><i class="fas fa-building mr-1"></i> Buildings</th>
                                                <th><i class="fas fa-box mr-1"></i> Items</th>
                                                <th><i class="fas fa-arrow-right mr-1"></i> Imports</th>
                                                <th><i class="fas fa-truck mr-1"></i> Exports</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (Factory factory in _factories)
                                            {
                                                <tr class="@(factory.HasProblem ? "summary-row-problem" : "")" role="button" @onclick="() => ScrollToFactory(factory)" @key="factory.Id">
                                                    <td>@factory.Name</td>
                                                    <td>
                                                        @foreach (KeyValuePair<string, BuildingRequirement> bldg in factory.BuildingRequirements.OrderBy(b => GameDataService.GetBuildingDisplayName(b.Key)))
                                                        {
                                                            <span class="sf-chip small orange no-margin mr-1" @key="bldg.Key">
                                                                <GameAsset Subject="@bldg.Key" Type="building" Height="20" Width="20" />
                                                                <span class="ml-1"><b>@GameDataService.GetBuildingDisplayName(bldg.Key)</b>: @FormatNumber(bldg.Value.Amount)x</span>
                                                            </span>
                                                        }
                                                    </td>
                                                    <td>
                                                        @foreach (FactoryItem product in factory.Products.OrderBy(p => GameDataService.GetPartDisplayName(p.Id)))
                                                        {
                                                            <span class="sf-chip small no-margin mr-1 @(factory.Parts.TryGetValue(product.Id, out PartMetrics? pm) && pm.AmountRemaining < 0 ? "red" : "")"
                                                                  @key="product"
                                                                  style="@(string.IsNullOrEmpty(product.Id) ? HiddenStyle : string.Empty)">
                                                                <GameAsset Subject="@product.Id" Type="item" Height="20" Width="20" />
                                                                <span class="ml-1"><b>@GameDataService.GetPartDisplayName(product.Id)</b>: @FormatNumber(product.Amount)/min</span>
                                                            </span>
                                                        }
                                                    </td>
                                                    <td>
                                                        @{ List<SummaryImport> imports = GetSummaryImports(factory); }
                                                        @foreach (SummaryImport imp in imports)
                                                        {
                                                            <span class="sf-chip small blue no-margin mr-1" @key="imp.PartId">
                                                                <GameAsset Subject="@imp.PartId" Type="item" Height="20" Width="20" />
                                                                <span class="ml-1"><b>@GameDataService.GetPartDisplayName(imp.PartId)</b>: @FormatNumber(imp.Amount)/min</span>
                                                            </span>
                                                        }
                                                    </td>
                                                    <td>
                                                        @{ List<SummaryExport> exports = GetSummaryExports(factory); }
                                                        @foreach (SummaryExport exp in exports)
                                                        {
                                                            <span class="sf-chip small blue no-margin mr-1" @key="exp.PartId">
                                                                <GameAsset Subject="@exp.PartId" Type="item" Height="20" Width="20" />
                                                                <span class="ml-1"><b>@GameDataService.GetPartDisplayName(exp.PartId)</b>: @FormatNumber(exp.Amount)/min</span>
                                                            </span>
                                                        }
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }
                        </div>

                        <div class="factories-content">
                            @foreach (Factory factory in _factories)
                            {
                                <div class="factory-card @(factory.HasProblem ? "factory-card-problem" : "")" id="factory-@factory.Id" @key="factory.Id">
                                    <!-- Factory Header -->
                                    <div class="factory-header">
                                        <div class="factory-header-left">
                                            <i class="fas fa-industry mr-2"></i>
                                            <input class="factory-name-input"
                                                   value="@factory.Name"
                                                   placeholder="Factory Name"
                                                   aria-label="Factory name"
                                                   @onchange="(e) => RenameFactory(factory, e.Value?.ToString() ?? string.Empty)" />
                                            <!-- Notes/Tasks chips -->
                                            @{
                                                string tasksAnchorId = $"tasks-{factory.Id}";
                                                string notesAnchorId = $"notes-{factory.Id}";
                                                int activeTaskCount = factory.Tasks.Count(t => !t.Completed);
                                            }
                                            <div class="factory-chips ml-2">
                                                @if (activeTaskCount > 0)
                                                {
                                                    <span class="sf-chip yellow small no-margin mr-1" role="button" title="View tasks" @onclick="() => ScrollToSection(factory, tasksAnchorId)">
                                                        <i class="fas fa-tasks"></i>
                                                        <span class="ml-1">Tasks: @activeTaskCount</span>
                                                    </span>
                                                }
                                                @if (!string.IsNullOrEmpty(factory.Notes))
                                                {
                                                    <span class="sf-chip yellow small no-margin" role="button" title="View notes" @onclick="() => ScrollToSection(factory, notesAnchorId)">
                                                        <i class="fas fa-sticky-note"></i>
                                                        <span class="ml-1">See notes</span>
                                                    </span>
                                                }
                                            </div>
                                        </div>
                                        <!-- Sync status chips -->
                                        <div class="factory-sync-status">
                                            @if (factory.InSync == true)
                                            {
                                                <span class="sf-chip green small" role="button" title="Click to re-sync" @onclick="() => HandleSetSyncState(factory)">
                                                    <i class="fas fa-check-square"></i>
                                                    <span class="ml-2">In sync with game</span>
                                                    <button class="btn btn-link btn-sm p-0 ml-2" title="Reset sync status" @onclick:stopPropagation="true" @onclick="() => HandleResetSyncState(factory)">
                                                        <i class="fas fa-times"></i>
                                                    </button>
                                                </span>
                                            }
                                            else if (factory.InSync == false)
                                            {
                                                <span class="sf-chip orange small" role="button" title="Click to re-sync" @onclick="() => HandleSetSyncState(factory)">
                                                    <i class="fas fa-times-square"></i>
                                                    <span class="ml-2">Out of sync with game</span>
                                                    <button class="btn btn-link btn-sm p-0 ml-2" title="Reset sync status" @onclick:stopPropagation="true" @onclick="() => HandleResetSyncState(factory)">
                                                        <i class="fas fa-times"></i>
                                                    </button>
                                                </span>
                                            }
                                            else
                                            {
                                                bool validForSync = FactoryCalcService.ValidForGameSync(factory);
                                                <span class="sf-chip small @(validForSync ? "" : "disabled")"
                                                      role="button"
                                                      title="@(validForSync ? "Mark as in sync with game" : "Add products or power producers first")"
                                                      @onclick="() => HandleSetSyncState(factory)">
                                                    <i class="fas fa-question"></i>
                                                    <span class="ml-2">Mark as in sync with game</span>
                                                </span>
                                            }
                                        </div>
                                        <div class="factory-actions">
                                            <button class="btn btn-sm btn-outline-secondary"
                                                    title="Move Up"
                                                    disabled="@(factory.DisplayOrder == 0)"
                                                    @onclick="() => MoveFactory(factory, -1)">
                                                <i class="fas fa-arrow-up"></i>
                                            </button>
                                            <button class="btn btn-sm btn-outline-secondary"
                                                    title="Move Down"
                                                    disabled="@(factory.DisplayOrder == _factories.Count - 1)"
                                                    @onclick="() => MoveFactory(factory, 1)">
                                                <i class="fas fa-arrow-down"></i>
                                            </button>
                                            <button class="btn btn-sm btn-outline-secondary"
                                                    title="@(factory.Hidden ? "Expand" : "Collapse")"
                                                    @onclick="() => ToggleFactory(factory)">
                                                <i class="fas @(factory.Hidden ? "fa-expand-alt" : "fa-compress-alt")"></i>
                                            </button>
                                            <button class="btn btn-sm btn-outline-warning" title="Copy Factory" @onclick="() => CopyFactory(factory)">
                                                <i class="fas fa-copy"></i>
                                            </button>
                                            <button class="btn btn-sm btn-danger" title="Delete" @onclick="() => DeleteFactory(factory)">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </div>
                                    </div>

                                    @if (!factory.Hidden)
                                    {
                                        <div class="factory-body">
                                            <!-- Products & Power Generators Section -->
                                            <div class="factory-section">
                                                <h5 class="section-heading">
                                                    <i class="fas fa-conveyor-belt-alt mr-2"></i>Products &amp; Power Generators
                                                </h5>
                                                @if (factory.Products.Count == 0)
                                                {
                                                    <p class="text-grey">No products. Add a product to this factory.</p>
                                                }
                                                @foreach (FactoryItem product in factory.Products)
                                                {
                                                    <div @key="product" class="product-iteration">
                                                        <div class="product-row">
                                                            <span class="product-icon-slot">
                                                                <GameAsset Subject="@product.Id" Type="item" Height="32" Width="32" ShowDefaultIcon="true" />
                                                            </span>
                                                            <select class="form-control product-part-select"
                                                                    value="@product.Id"
                                                                    @onchange="async (e) => await OnPartSelected(product, factory, e.Value?.ToString() ?? string.Empty)">
                                                                <option value="">-- Select Part --</option>
                                                                @foreach (KeyValuePair<string, Part> partEntry in GetSortedParts())
                                                                {
                                                                    <option value="@partEntry.Key">@partEntry.Value.Name</option>
                                                                }
                                                            </select>
                                                            <span class="product-recipe-slot">
                                                                <i class="fas fa-hat-chef product-icon" style="@RecipeSlotDisplayStyle(product.Id)"></i>
                                                                <select class="form-control product-recipe-select"
                                                                        style="@RecipeSlotDisplayStyle(product.Id)"
                                                                        value="@product.Recipe"
                                                                        @onchange="(e) => OnRecipeSelected(product, factory, e.Value?.ToString() ?? string.Empty)">
                                                                    @foreach (Recipe recipe in GameDataService.GetRecipesForPart(product.Id))
                                                                    {
                                                                        <option value="@recipe.Id">@recipe.DisplayName@(recipe.IsAlternate ? " (Alt)" : "")</option>
                                                                    }
                                                                </select>
                                                                <input type="number"
                                                                       style="@RecipeSlotDisplayStyle(product.Id)"
                                                                       class="form-control product-amount-input"
                                                                       value="@product.Amount"
                                                                       min="1"
                                                                       @onchange="(e) => OnAmountChanged(product, factory, e.Value?.ToString() ?? string.Empty)" />
                                                            </span>
                                                            @if (ShouldShowFix(product, factory) == "deficit")
                                                            {
                                                                <button class="btn btn-sm btn-success mr-1" title="Satisfy - increase amount to meet requirements" @onclick="() => FixProduct(product, factory)">
                                                                    <i class="fas fa-arrow-up mr-1"></i>Satisfy
                                                                </button>
                                                            }
                                                            @if (ShouldShowFix(product, factory) == "surplus")
                                                            {
                                                                <button class="btn btn-sm btn-warning mr-1" title="Trim - reduce amount to match requirements" @onclick="() => FixProduct(product, factory)">
                                                                    <i class="fas fa-arrow-down mr-1"></i>Trim
                                                                </button>
                                                            }
                                                            <button class="btn btn-sm btn-danger" title="Remove" @onclick="() => RemoveProduct(factory, product)">
                                                                <i class="fas fa-trash"></i>
                                                            </button>
                                                            @if (ShouldShowNotInDemand(product, factory))
                                                            {
                                                                <span class="sf-chip orange small ml-2">No demand!</span>
                                                            }
                                                        </div>
                                                        @if (!string.IsNullOrEmpty(product.Recipe) && (product.Requirements.Count > 0 || !string.IsNullOrEmpty(product.BuildingRequirements.Name)))
                                                        {
                                                            <div class="product-requires-row">
                                                                <span class="requires-label">Requires:</span>
                                                                @foreach (KeyValuePair<string, RequirementAmount> req in product.Requirements)
                                                                {
                                                                    bool isRaw = factory.Parts.TryGetValue(req.Key, out PartMetrics? pm) && pm.IsRaw;
                                                                    <span class="sf-chip small @(isRaw ? "cyan" : "blue")">
                                                                        <GameAsset Subject="@req.Key" Type="item" Height="20" Width="20" />
                                                                        <span class="ml-1"><b>@GameDataService.GetPartDisplayName(req.Key)</b>: @FormatNumber(req.Value.Amount)/min</span>
                                                                    </span>
                                                                }
                                                                @if (!string.IsNullOrEmpty(product.BuildingRequirements.Name))
                                                                {
                                                                    <span class="sf-chip small orange">
                                                                        <GameAsset Subject="@product.BuildingRequirements.Name" Type="building" Height="20" Width="20" />
                                                                        <span class="ml-1"><b>@GameDataService.GetBuildingDisplayName(product.BuildingRequirements.Name)</b>: @FormatNumber(product.BuildingRequirements.Amount)x</span>
                                                                    </span>
                                                                    <span class="sf-chip small yellow">
                                                                        <i class="fas fa-bolt mr-1"></i><i class="fas fa-minus mr-1"></i>
                                                                        <span>@FormatPower(product.BuildingRequirements.PowerConsumed ?? 0)</span>
                                                                    </span>
                                                                }
                                                            </div>
                                                        }
                                                    </div>
                                                }
                                                <div class="factory-add-part mt-2">
                                                    <button class="btn btn-sm btn-primary" @onclick="() => AddEmptyProduct(factory)">
                                                        <i class="fas fa-plus"></i> Add Product
                                                    </button>
                                                </div>

                                                <!-- Power Producers -->
                                                @foreach (FactoryPowerProducer producer in factory.PowerProducers)
                                                {
                                                    <div class="product-row mt-2" @key="producer">
                                                        <select class="form-control product-part-select"
                                                                value="@producer.Building"
                                                                @onchange="(e) => OnPowerProducerBuildingChanged(producer, factory, e.Value?.ToString() ?? string.Empty)">
                                                            <option value="">-- Select Generator --</option>
                                                            @foreach (string building in GetPowerProducerBuildings())
                                                            {
                                                                <option value="@building">@GameDataService.GetBuildingDisplayName(building)</option>
                                                            }
                                                        </select>
                                                        @if (!string.IsNullOrEmpty(producer.Building))
                                                        {
                                                            <select class="form-control product-recipe-select"
                                                                    value="@producer.Recipe"
                                                                    @onchange="(e) => OnPowerProducerRecipeChanged(producer, factory, e.Value?.ToString() ?? string.Empty)">
                                                                <option value="">-- Select Fuel --</option>
                                                                @foreach (PowerRecipe recipe in GameDataService.GetRecipesForPowerProducer(producer.Building))
                                                                {
                                                                    <option value="@recipe.Id">@GetFuelDisplayName(recipe.DisplayName)</option>
                                                                }
                                                            </select>
                                                        }
                                                        @if (!string.IsNullOrEmpty(producer.Recipe))
                                                        {
                                                            <input type="number"
                                                                   class="form-control product-amount-input"
                                                                   value="@producer.IngredientAmount"
                                                                   min="0"
                                                                   placeholder="Fuel/min"
                                                                   @onchange="(e) => OnPowerProducerIngredientChanged(producer, factory, e.Value?.ToString() ?? string.Empty)" />
                                                            <input type="number"
                                                                   class="form-control product-amount-input"
                                                                   value="@producer.PowerAmount"
                                                                   min="0"
                                                                   placeholder="MW"
                                                                   @onchange="(e) => OnPowerProducerPowerChanged(producer, factory, e.Value?.ToString() ?? string.Empty)" />
                                                        }
                                                        <button class="btn btn-sm btn-danger" title="Remove" @onclick="() => RemovePowerProducer(factory, producer)">
                                                            <i class="fas fa-trash"></i>
                                                        </button>
                                                    </div>
                                                }
                                                <div class="factory-add-part mt-2">
                                                    <button class="btn btn-sm btn-warning" @onclick="() => AddEmptyPowerProducer(factory)">
                                                        <i class="fas fa-bolt"></i> Add Power Generator
                                                    </button>
                                                </div>
                                            </div>

                                            @if (factory.PowerProducers.Count > 0)
                                            {
                                                <hr class="factory-divider" />
                                                <div class="factory-section">
                                                    <h5 class="section-heading">
                                                        <i class="fas fa-bolt mr-2"></i>Power Generators
                                                    </h5>
                                                    @foreach (FactoryPowerProducer producer in factory.PowerProducers)
                                                    {
                                                        @if (!string.IsNullOrEmpty(producer.Recipe))
                                                        {
                                                            <div class="product-requires-row">
                                                                <span class="requires-label">@GameDataService.GetBuildingDisplayName(producer.Building) Requires:</span>
                                                                @if (producer.Ingredients.Count > 1)
                                                                {
                                                                    Web.Models.Factory.PowerItem supplementalIngredient = producer.Ingredients[1];
                                                                    <span class="sf-chip small blue">
                                                                        <GameAsset Subject="@supplementalIngredient.Part" Type="item" Height="20" Width="20" />
                                                                        <span class="ml-1"><b>@GameDataService.GetPartDisplayName(supplementalIngredient.Part)</b>: @FormatNumber(supplementalIngredient.PerMin)/min</span>
                                                                    </span>
                                                                }
                                                                <span class="sf-chip small orange">
                                                                    <GameAsset Subject="@producer.Building" Type="building" Height="20" Width="20" />
                                                                    <span class="ml-1"><b>@GameDataService.GetBuildingDisplayName(producer.Building)</b>: @FormatNumber(producer.BuildingAmount)x</span>
                                                                </span>
                                                                <span class="sf-chip small yellow">
                                                                    <i class="fas fa-bolt mr-1"></i><i class="fas fa-plus mr-1"></i>
                                                                    <span>@FormatPower(producer.PowerAmount)</span>
                                                                </span>
                                                            </div>
                                                        }
                                                    }
                                                </div>
                                            }

                                            <hr class="factory-divider" />

                                            <!-- Imports Section -->
                                            <div class="factory-section">
                                                <h5 class="section-heading">
                                                    <i class="fas fa-arrow-to-right mr-2"></i>Imports
                                                </h5>
                                                @foreach (FactoryInput input in factory.Inputs)
                                                {
                                                    <div class="product-row mb-2" @key="input">
                                                        <i class="fas fa-industry mr-2"></i>
                                                        <select class="form-control product-part-select"
                                                                value="@(input.FactoryId?.ToString() ?? string.Empty)"
                                                                @onchange="(e) => OnInputFactoryChanged(factory, input, e.Value?.ToString() ?? string.Empty)">
                                                            <option value="">-- Select Factory --</option>
                                                            @foreach (Factory supplierFactory in GetImportableFactories(factory))
                                                            {
                                                                <option value="@supplierFactory.Id">@supplierFactory.Name</option>
                                                            }
                                                        </select>
                                                        @if (input.FactoryId.HasValue)
                                                        {
                                                            <span class="mr-2">
                                                                @if (!string.IsNullOrEmpty(input.OutputPart))
                                                                {
                                                                    <GameAsset Subject="@input.OutputPart" Type="item" Height="32" Width="32" />
                                                                }
                                                                else
                                                                {
                                                                    <i class="fas fa-cube" style="width: 32px; height: 32px"></i>
                                                                }
                                                            </span>
                                                            <select class="form-control product-recipe-select"
                                                                    value="@(input.OutputPart ?? string.Empty)"
                                                                    @onchange="(e) => OnInputPartChanged(factory, input, e.Value?.ToString() ?? string.Empty)">
                                                                <option value="">-- Select Part --</option>
                                                                @foreach (KeyValuePair<string, PartMetrics> partEntry in GetExportablePartsForFactory(input.FactoryId.Value))
                                                                {
                                                                    <option value="@partEntry.Key">@GameDataService.GetPartDisplayName(partEntry.Key)</option>
                                                                }
                                                            </select>
                                                        }
                                                        @if (!string.IsNullOrEmpty(input.OutputPart))
                                                        {
                                                            <input type="number"
                                                                   class="form-control product-amount-input"
                                                                   value="@input.Amount"
                                                                   min="0"
                                                                   @onchange="(e) => OnInputAmountChanged(factory, input, e.Value?.ToString() ?? string.Empty)" />
                                                        }
                                                        @if (!string.IsNullOrEmpty(input.OutputPart) && !RequirementSatisfied(factory, input.OutputPart))
                                                        {
                                                            <button class="btn btn-sm btn-success mr-1" title="Satisfy - set amount to meet requirements" @onclick="() => SatisfyImport(factory, input)">
                                                                <i class="fas fa-arrow-up mr-1"></i>Satisfy
                                                            </button>
                                                        }
                                                        @if (!string.IsNullOrEmpty(input.OutputPart) && RequirementSatisfied(factory, input.OutputPart) && ShowInputOverflow(factory, input.OutputPart))
                                                        {
                                                            <button class="btn btn-sm btn-warning mr-1" title="Trim - reduce amount to match requirements" @onclick="() => SatisfyImport(factory, input)">
                                                                <i class="fas fa-arrow-down mr-1"></i>Trim
                                                            </button>
                                                        }
                                                        <button class="btn btn-sm btn-outline-primary mr-1"
                                                                title="View Factory"
                                                                disabled="@(!input.FactoryId.HasValue)"
                                                                @onclick="() => NavigateToFactory(input.FactoryId)">
                                                            <i class="fas fa-industry mr-1"></i>View
                                                        </button>
                                                        <button class="btn btn-sm btn-danger" title="Remove Import" @onclick="() => RemoveInput(factory, input)">
                                                            <i class="fas fa-trash"></i>
                                                        </button>
                                                        @if (!string.IsNullOrEmpty(input.OutputPart) && input.Amount == 0)
                                                        {
                                                            <span class="sf-chip red small"><i class="fas fa-exclamation-triangle"></i><span class="ml-2">No amount set!</span></span>
                                                        }
                                                    </div>
                                                }
                                                <div class="factory-add-part mt-2">
                                                    <button class="btn btn-sm btn-success"
                                                            disabled="@(GetImportableFactories(factory).Count == 0)"
                                                            title="@(GetImportableFactories(factory).Count == 0 ? "No other factories with available outputs" : "Add Import")"
                                                            @onclick="() => AddEmptyInput(factory)">
                                                        <i class="fas fa-dolly"></i> Add Import
                                                    </button>
                                                    @if (GetImportableFactories(factory).Count == 0 && factory.Inputs.Count == 0)
                                                    {
                                                        <span class="text-grey ml-2">No other factories with available outputs.</span>
                                                    }
                                                </div>
                                                @if (factory.RawResources.Count > 0)
                                                {
                                                    <div class="raw-resources-section mt-3">
                                                        <h6 class="section-subheading">
                                                            <i class="fas fa-hard-hat mr-2"></i>Raw Resources
                                                        </h6>
                                                        <p class="text-grey text-small mb-2">
                                                            <i class="fas fa-info-circle mr-1"></i>Raw resources (e.g. Iron Ore) aren't defined as imports. It is assumed you'll supply them sufficiently.
                                                        </p>
                                                        <div class="d-flex flex-wrap gap-2">
                                                            @foreach (KeyValuePair<string, WorldRawResource> resource in factory.RawResources)
                                                            {
                                                                <span class="sf-chip small cyan">
                                                                    <GameAsset Subject="@resource.Key" Type="item" Height="20" Width="20" />
                                                                    <span class="ml-2"><b>@resource.Value.Name</b>: @FormatNumber(resource.Value.Amount)/min</span>
                                                                </span>
                                                            }
                                                        </div>
                                                    </div>
                                                }
                                            </div>

                                            <hr class="factory-divider" />

                                            <!-- Satisfaction Section -->
                                            <div class="factory-section">
                                                <h5 class="section-heading @(factory.RequirementsSatisfied ? "" : "text-red")">
                                                    <i class="fas @(factory.Parts.Count == 0 ? "fa-question" : (factory.RequirementsSatisfied ? "fa-check" : "fa-times")) mr-2"></i>Satisfaction
                                                </h5>
                                                @if (factory.Parts.Count == 0)
                                                {
                                                    <p class="text-grey">Awaiting product selection.</p>
                                                }
                                                else
                                                {
                                                    <!-- Parts table -->
                                                    <div class="satisfaction-table-wrapper">
                                                        <table class="satisfaction-table">
                                                            <thead>
                                                                <tr>
                                                                    <th class="sat-col-item">Item</th>
                                                                    <th class="sat-col-satisfaction">Satisfaction</th>
                                                                </tr>
                                                            </thead>
                                                            <tbody>
                                                                @foreach (KeyValuePair<string, PartMetrics> partEntry in factory.Parts)
                                                                {
                                                                    <tr class="@(partEntry.Value.Satisfied ? "sat-row-ok" : "sat-row-fail")" @key="partEntry.Key">
                                                                        <td class="sat-col-item">
                                                                            <div class="d-flex align-items-center">
                                                                                <GameAsset Subject="@partEntry.Key" Type="item" Height="32" Width="32" />
                                                                                <span class="ml-2 @(partEntry.Value.Satisfied ? "text-green" : "text-red")">
                                                                                    <i class="fas @(partEntry.Value.Satisfied ? "fa-check" : "fa-times") mr-1"></i>
                                                                                    <b>@GameDataService.GetPartDisplayName(partEntry.Key)</b>
                                                                                </span>
                                                                                @if (partEntry.Value.IsRaw)
                                                                                {
                                                                                    <span class="sf-chip cyan x-small ml-2">Raw</span>
                                                                                }
                                                                            </div>
                                                                            @if (!partEntry.Value.Satisfied)
                                                                            {
                                                                                <div class="sat-action-buttons mt-1">
                                                                                    @if (ShowAddProductButton(factory, partEntry.Key, partEntry.Value))
                                                                                    {
                                                                                        <button class="btn btn-sm btn-success mr-1"
                                                                                                title="Add product to produce this item"
                                                                                                @onclick="() => AddProductFromSatisfaction(factory, partEntry.Key, partEntry.Value)">
                                                                                            <i class="fas fa-plus"></i> Add Product
                                                                                        </button>
                                                                                    }
                                                                                    @if (ShowFixImportButton(factory, partEntry.Key, partEntry.Value) == "single")
                                                                                    {
                                                                                        <button class="btn btn-sm btn-success mr-1"
                                                                                                title="Fix import amount to satisfy this item"
                                                                                                @onclick="() => FixImportFromSatisfaction(factory, partEntry.Key)">
                                                                                            <i class="fas fa-arrow-up"></i> Fix Import
                                                                                        </button>
                                                                                    }
                                                                                    @if (ShowFixImportButton(factory, partEntry.Key, partEntry.Value) == "multiple")
                                                                                    {
                                                                                        <span class="sf-chip grey small" title="There are multiple imports for this item. Please correct manually using the Imports section.">
                                                                                            <i class="fas fa-exclamation-circle mr-1"></i>Fix Import (manual)
                                                                                        </span>
                                                                                    }
                                                                                </div>
                                                                            }
                                                                        </td>
                                                                        <td class="sat-col-satisfaction">
                                                                            <span class="sf-chip @(partEntry.Value.Satisfied ? "green" : "red") small">
                                                                                <b>@FormatNumber(partEntry.Value.AmountRemaining)/min @(partEntry.Value.AmountRemaining >= 0 ? "surplus" : "shortage")</b>
                                                                            </span>
                                                                        </td>
                                                                    </tr>
                                                                }
                                                            </tbody>
                                                        </table>
                                                    </div>

                                                    <!-- Power & Buildings Card -->
                                                    <div class="power-buildings-card mt-3">
                                                        <h6 class="power-buildings-heading">
                                                            <i class="fas fa-building mr-2"></i>Power &amp; Buildings
                                                        </h6>
                                                        <div class="d-flex flex-wrap gap-2">
                                                            <span class="sf-chip small yellow">
                                                                <i class="fas fa-bolt mr-1"></i><i class="fas fa-minus mr-1"></i>
                                                                Consumes: @FormatPower(factory.Power.Consumed)
                                                            </span>
                                                            <span class="sf-chip small yellow">
                                                                <i class="fas fa-bolt mr-1"></i><i class="fas fa-plus mr-1"></i>
                                                                Produces: @FormatPower(factory.Power.Produced)
                                                            </span>
                                                            @foreach (KeyValuePair<string, BuildingRequirement> bldg in factory.BuildingRequirements)
                                                            {
                                                                <span class="sf-chip small orange">
                                                                    <GameAsset Subject="@bldg.Value.Name" Type="building" Height="20" Width="20" />
                                                                    <span class="ml-1"><b>@GameDataService.GetBuildingDisplayName(bldg.Value.Name)</b>: @FormatNumber(bldg.Value.Amount)x</span>
                                                                </span>
                                                            }
                                                        </div>
                                                    </div>
                                                }
                                            </div>

                                            <hr class="factory-divider" />

                                            <!-- Tasks & Notes Row -->
                                            <div class="tasks-notes-row">
                                                <!-- Tasks -->
                                                <div class="sub-panel" id="tasks-@factory.Id">
                                                    <h5 class="section-heading">
                                                        <i class="fas fa-tasks mr-2"></i>Tasks
                                                    </h5>
                                                    <div class="task-input-row mb-2">
                                                        <input type="text"
                                                               class="form-control"
                                                               placeholder="Add a task..."
                                                               maxlength="200"
                                                               value="@GetNewTaskText(factory.Id)"
                                                               @onchange="(e) => SetNewTaskText(factory.Id, e.Value?.ToString() ?? string.Empty)"
                                                               @onkeydown="(e) => HandleTaskKeyDown(e, factory)" />
                                                        <button class="btn btn-sm btn-primary ml-2" @onclick="() => AddTask(factory)" title="Add task">
                                                            <i class="fas fa-plus"></i>
                                                        </button>
                                                    </div>
                                                    @if (factory.Tasks.Count >= 40)
                                                    {
                                                        <p class="text-red">You are only allowed up to 50 tasks.</p>
                                                    }
                                                    @if (factory.Tasks.Count > 0)
                                                    {
                                                        <table class="task-table">
                                                            <tbody>
                                                                @for (int ti = 0; ti < factory.Tasks.Count; ti++)
                                                                {
                                                                    int taskIndex = ti;
                                                                    FactoryTask task = factory.Tasks[taskIndex];
                                                                    <tr>
                                                                        <td class="task-title-cell">
                                                                            @if (task.Completed)
                                                                            {
                                                                                <span class="task-done">@task.Title</span>
                                                                            }
                                                                            else
                                                                            {
                                                                                <input type="text"
                                                                                       class="form-control form-control-sm"
                                                                                       maxlength="200"
                                                                                       value="@task.Title"
                                                                                       @onchange="(e) => UpdateTaskTitle(factory, taskIndex, e.Value?.ToString() ?? string.Empty)" />
                                                                            }
                                                                        </td>
                                                                        <td class="task-actions-cell">
                                                                            @if (!task.Completed)
                                                                            {
                                                                                <button class="btn btn-sm btn-outline-info mr-1" title="Mark complete" @onclick="() => ToggleTask(factory, taskIndex)">
                                                                                    <i class="fas fa-check-square"></i>
                                                                                </button>
                                                                            }
                                                                            else
                                                                            {
                                                                                <button class="btn btn-sm btn-outline-secondary mr-1" title="Mark incomplete" @onclick="() => ToggleTask(factory, taskIndex)">
                                                                                    <i class="fas fa-times"></i>
                                                                                </button>
                                                                            }
                                                                            <button class="btn btn-sm btn-danger" title="Delete task" @onclick="() => RemoveTask(factory, taskIndex)">
                                                                                <i class="fas fa-trash"></i>
                                                                            </button>
                                                                        </td>
                                                                    </tr>
                                                                }
                                                            </tbody>
                                                        </table>
                                                    }
                                                </div>

                                                <!-- Notes -->
                                                <div class="sub-panel" id="notes-@factory.Id">
                                                    <h5 class="section-heading">
                                                        <i class="fas fa-sticky-note mr-2"></i>Notes
                                                    </h5>
                                                    <textarea class="form-control notes-textarea"
                                                              placeholder="Add some notes!"
                                                              maxlength="1000"
                                                              rows="4"
                                                              value="@factory.Notes"
                                                              @onchange="(e) => UpdateNotes(factory, e.Value?.ToString() ?? string.Empty)"></textarea>
                                                    @if (!string.IsNullOrEmpty(factory.Notes))
                                                    {
                                                        <button class="btn btn-sm btn-primary mt-2" @onclick="() => UpdateNotes(factory, string.Empty)">Clear Notes</button>
                                                    }
                                                </div>
                                            </div>
                                        </div>
                                    }
                                    else
                                    {
                                        <!-- Collapsed view: just show product chips -->
                                        <div class="factory-body factory-body-collapsed">
                                            @if (factory.Products.Count == 0)
                                            {
                                                <p class="text-grey">Empty factory! Select a product!</p>
                                            }
                                            else
                                            {
                                                <span class="mr-2"><b>Producing:</b></span>
                                                @foreach (FactoryItem product in factory.Products)
                                                {
                                                    @if (!string.IsNullOrEmpty(product.Id))
                                                    {
                                                        <span class="sf-chip @CollapsedProductChipClass(factory, product.Id)">
                                                            <GameAsset Subject="@product.Id" Type="item" Height="24" Width="24" />
                                                            <span class="ml-1"><b>@GameDataService.GetPartDisplayName(product.Id)</b>: @FormatNumber(product.Amount)/min</span>
                                                        </span>
                                                    }
                                                }
                                            }
                                        </div>
                                    }
                                </div>
                            }
                            <div class="text-center mt-4">
                                <button class="btn btn-primary btn-lg" @onclick="CreateFactory">
                                    <i class="fas fa-plus"></i> Add Factory
                                </button>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
</div>

@code {
    private bool _isLoaded = false;
    private List<Factory> _factories = new List<Factory>();
    private GameData? _gameData;
    private int _nextFactoryId = 1;
    private bool _statisticsHidden = false;
    private bool _statisticsProductsHidden = true;
    private bool _summarySectionHidden = false;
    private Dictionary<int, string> _newTaskText = new Dictionary<int, string>();
    private bool _showIntroDialog = false;
    private bool _disableRecalc = false;
    private int _renderCount = 0;

    // Simple statistics record types for aggregation
    private record StatRawResource(string Id, double TotalAmount);
    private record StatBuilding(string Name, double TotalAmount);
    private record StatPartDifference(string Id, double AmountRemaining);
    private record StatProducedItem(string Id, double AmountSupplied);
    private record SummaryImport(string PartId, double Amount);
    private record SummaryExport(string PartId, double Amount);

    protected override void OnAfterRender(bool firstRender)
    {
        _renderCount++;
        Console.WriteLine($"Home: OnAfterRender #{_renderCount} (firstRender={firstRender}), factories={_factories.Count}, isLoaded={_isLoaded}");
    }

    protected override async Task OnInitializedAsync()
    {
        AppState.OnChange += StateHasChanged;

        _gameData = await GameDataService.LoadGameDataAsync();

        await AppState.LoadFactoriesAsync();
        _factories = AppState.GetFactories();

        // Run initial calculations for loaded factories
        if (_gameData != null && _factories.Count > 0)
        {
            try
            {
                FactoryCalcService.CalculateFactories(_factories, _gameData);
            }
            catch (Exception ex)
            {
                Console.Error.WriteLine($"Home: Error during initial factory calculation: {ex}");
                ToastService.ShowToast("An error occurred while loading your factories. Some data may be in an inconsistent state.", ToastType.Error);
            }
        }

        string currentUrl = NavManager.Uri;
        if (currentUrl.Contains("setupDemo=true", StringComparison.OrdinalIgnoreCase))
        {
            await LoadDemoPlan();
        }

        _isLoaded = true;
    }

    private async Task LoadDemoPlan()
    {
        Console.WriteLine("Loading demo plan from query parameter");
        await DemoPlansService.LoadDemoPlanAsync("Simple");
        _factories = AppState.GetFactories();
        if (_gameData != null)
        {
            try
            {
                FactoryCalcService.CalculateFactories(_factories, _gameData);
            }
            catch (Exception ex)
            {
                Console.Error.WriteLine($"Home: Error during demo plan factory calculation: {ex}");
                ToastService.ShowToast("An error occurred while loading the demo plan.", ToastType.Error);
            }
        }
        Console.WriteLine("Demo plan loaded successfully");
    }

    private void HandleTemplateLoaded()
    {
        Console.WriteLine("Home: HandleTemplateLoaded called");
        _factories = AppState.GetFactories();
        Console.WriteLine($"Home: Retrieved {_factories.Count} factories from AppState");
        if (_gameData != null)
        {
            try
            {
                FactoryCalcService.CalculateFactories(_factories, _gameData);
                Console.WriteLine("Home: Recalculated all factories after template load");
            }
            catch (Exception ex)
            {
                Console.Error.WriteLine($"Home: HandleTemplateLoaded - Error during factory calculation: {ex}");
                ToastService.ShowToast("An error occurred while loading the template.", ToastType.Error);
            }
        }
        else
        {
            Console.Error.WriteLine("Home: HandleTemplateLoaded - _gameData is null, cannot recalculate factories");
        }
    }

    private void RecalculateAll()
    {
        Console.WriteLine($"Home: RecalculateAll start (renderCount={_renderCount}, factories={_factories.Count})");
        try
        {
            if (_gameData != null)
            {
                FactoryCalcService.CalculateFactories(_factories, _gameData);
            }
            Console.WriteLine($"Home: RecalculateAll complete (renderCount={_renderCount})");
            _ = AppState.SaveFactoriesAsync();
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"RecalculateAll: Error during factory calculation: {ex}");
            string errorMessage;
            if (string.IsNullOrEmpty(ex.Message))
            {
                errorMessage = $"An unexpected error occurred ({ex.GetType().Name}). Please check the browser console for details.";
            }
            else
            {
                errorMessage = ex.Message;
            }
            ToastService.ShowToast($"An error occurred while calculating factories: {errorMessage}", ToastType.Error);
        }
    }

    private void ShowIntro()
    {
        _showIntroDialog = true;
    }

    private void HandleIntroClosed()
    {
        _showIntroDialog = false;
    }

    private async Task ForceRecalculate()
    {
        bool confirmed = await JSRuntime.InvokeAsync<bool>("confirm", "WARNING: Forcing a recalculation takes a LONG time for large plans. Your browser will lag and will likely complain about stalling. Are you sure?");
        if (!confirmed) return;

        ToastService.ShowToast("Forcing recalculation of all factories. This may take a while for large plans.", ToastType.Info);
        _disableRecalc = true;
        StateHasChanged();

        try
        {
            RecalculateAll();
            ToastService.ShowToast("Recalculations completed.", ToastType.Success);
        }
        finally
        {
            _disableRecalc = false;
            StateHasChanged();
        }
    }

    private void CreateFactory()
    {
        Factory factory = new Factory
        {
            Id = _nextFactoryId++,
            Name = $"Factory {_nextFactoryId - 1}",
            DisplayOrder = _factories.Count,
            Hidden = false,
            Products = new List<FactoryItem>(),
            Inputs = new List<FactoryInput>(),
            Parts = new Dictionary<string, PartMetrics>(),
            BuildingRequirements = new Dictionary<string, BuildingRequirement>(),
            PowerProducers = new List<FactoryPowerProducer>(),
            Power = new FactoryPower(),
            Tasks = new List<FactoryTask>(),
            Dependencies = new FactoryDependency(),
            SyncState = new Dictionary<string, FactorySyncState>(),
            SyncStatePower = new Dictionary<string, FactoryPowerSyncState>()
        };

        AppState.AddFactory(factory);
        _factories = AppState.GetFactories();
        _ = AppState.SaveFactoriesAsync();
    }

    private void RenameFactory(Factory factory, string newName)
    {
        factory.Name = newName;
        _ = AppState.SaveFactoriesAsync();
    }

    private void ToggleFactory(Factory factory)
    {
        factory.Hidden = !factory.Hidden;
        _ = AppState.SaveFactoriesAsync();
    }

    private void HandleSetSyncState(Factory factory)
    {
        if (!FactoryCalcService.ValidForGameSync(factory))
        {
            return;
        }
        FactoryCalcService.SetSyncState(factory);
        _ = AppState.SaveFactoriesAsync();
    }

    private void HandleResetSyncState(Factory factory)
    {
        FactoryCalcService.ResetSyncState(factory);
        _ = AppState.SaveFactoriesAsync();
    }

    private void MoveFactory(Factory factory, int direction)
    {
        int currentOrder = factory.DisplayOrder;
        int newOrder = currentOrder + direction;
        if (newOrder < 0 || newOrder >= _factories.Count)
        {
            return;
        }

        Factory? other = _factories.FirstOrDefault(f => f.DisplayOrder == newOrder);
        if (other != null)
        {
            other.DisplayOrder = currentOrder;
        }
        factory.DisplayOrder = newOrder;

        _factories.Sort((a, b) => a.DisplayOrder.CompareTo(b.DisplayOrder));
        _ = AppState.SaveFactoriesAsync();
    }

