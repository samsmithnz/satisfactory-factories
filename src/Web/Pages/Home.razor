    private async Task CopyPlanToClipboard()
    {
        string plan = System.Text.Json.JsonSerializer.Serialize(_factories);
        await JSRuntime.InvokeVoidAsync("navigator.clipboard.writeText", plan);
        ToastService.ShowToast("Plan copied to clipboard! You can save it to a file or paste it.", ToastType.Success);
