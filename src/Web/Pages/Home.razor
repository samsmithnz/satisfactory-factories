    /// <summary>
    /// Adds a product to the factory to satisfy the given part's deficit.
    /// </summary>
    private void AddProductFromSatisfaction(Factory factory, string partId, PartMetrics part)
    {
        string defaultRecipe = GameDataService.GetDefaultRecipeForPart(partId);
        FactoryItem newProduct = new FactoryItem
        {
            Id = partId,
            Amount = Math.Abs(part.AmountRemaining),
            Recipe = defaultRecipe,
            DisplayOrder = factory.Products.Count,
            Requirements = new Dictionary<string, RequirementAmount>(),
            BuildingRequirements = new BuildingRequirement()
        };
        factory.Products.Add(newProduct);
        RecalculateAll();
    }

    /// <summary>
    /// Fixes a single import's amount to satisfy the part's total requirement.
    /// Mirrors Vue's fixSatisfactionImport.
    /// </summary>
    private void FixImportFromSatisfaction(Factory factory, string partId)
    {
        FactoryInput? input = factory.Inputs.FirstOrDefault(i => i.OutputPart == partId);
        if (input == null) return;
        if (!factory.Parts.TryGetValue(partId, out PartMetrics? part)) return;
        input.Amount = part.AmountRequired;
        RecalculateAll();
    }

    private static bool ShouldShowNotInDemand(FactoryItem product, Factory factory)
    {
        if (string.IsNullOrEmpty(product.Id))
        {
            return false;
        }

        return factory.Parts.TryGetValue(product.Id, out PartMetrics? part) && part.AmountRequired <= 0;
    }

    /// <summary>
    /// Returns "deficit", "surplus", or null to indicate Satisfy/Trim button visibility.
    /// Mirrors Vue's shouldShowFix.
    /// </summary>
    private static string? ShouldShowFix(FactoryItem product, Factory factory)
    {
        if (string.IsNullOrEmpty(product.Id)) return null;
        if (!factory.Parts.TryGetValue(product.Id, out PartMetrics? part)) return null;
        if (product.Amount == 0 || product.Amount == 1) return null;
        if (part.AmountRemaining < 0) return "deficit";
        if (part.AmountRequired == 0) return null;
        if (part.AmountRemaining > 0) return "surplus";
        return null;
    }

    /// <summary>
    /// Adjusts a product's amount to exactly satisfy or trim to factory demand.
    /// Mirrors Vue's fixProduct.
    /// </summary>
    private void FixProduct(FactoryItem product, Factory factory)
    {
        if (string.IsNullOrEmpty(product.Id)) return;
        if (!factory.Parts.TryGetValue(product.Id, out PartMetrics? partData)) return;
        double diff = partData.AmountRequired - partData.AmountSuppliedViaProduction;
        product.Amount = product.Amount + diff;
        RecalculateAll();
    }

    private void CopyFactory(Factory original)
    {
        Factory copy = new Factory
        {
            Id = _nextFactoryId++,
            Name = $"{original.Name} (copy)",
            DisplayOrder = original.DisplayOrder + 1,
            Hidden = false,
            Products = original.Products.Select(p => new FactoryItem
            {
                Id = p.Id,
                Recipe = p.Recipe,
                Amount = p.Amount,
                DisplayOrder = p.DisplayOrder,
                Requirements = new Dictionary<string, RequirementAmount>(),
                BuildingRequirements = new BuildingRequirement()
            }).ToList(),
            Inputs = new List<FactoryInput>(),
            Parts = new Dictionary<string, PartMetrics>(),
            BuildingRequirements = new Dictionary<string, BuildingRequirement>(),
            PowerProducers = original.PowerProducers.Select(pp => new FactoryPowerProducer
            {
                Building = pp.Building,
                Recipe = pp.Recipe,
                IngredientAmount = pp.IngredientAmount,
                PowerAmount = pp.PowerAmount,
                BuildingAmount = pp.BuildingAmount,
                BuildingCount = pp.BuildingCount,
                Ingredients = pp.Ingredients.Select(i => new Web.Models.Factory.PowerItem { Part = i.Part, PerMin = i.PerMin }).ToList(),
                DisplayOrder = pp.DisplayOrder,
                Updated = null
            }).ToList(),
            Power = new FactoryPower(),
            Tasks = new List<FactoryTask>(),
            Notes = string.Empty,
            Dependencies = new FactoryDependency(),
            SyncState = new Dictionary<string, FactorySyncState>(),
            SyncStatePower = new Dictionary<string, FactoryPowerSyncState>(),
            InSync = null
        };

        // Shift display orders of factories after the insertion point
        foreach (Factory f in _factories.Where(f => f.DisplayOrder >= copy.DisplayOrder))
        {
            f.DisplayOrder += 1;
        }

        AppState.AddFactory(copy);
        _factories = AppState.GetFactories();
        _factories.Sort((a, b) => a.DisplayOrder.CompareTo(b.DisplayOrder));

        if (_gameData != null)
        {
            FactoryCalcService.CalculateFactories(_factories, _gameData);
        }

        _ = AppState.SaveFactoriesAsync();
    }

