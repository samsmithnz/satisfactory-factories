    private async Task PastePlanFromClipboard()
    {
        try
        {
            string plan = await JSRuntime.InvokeAsync<string>("navigator.clipboard.readText");
            if (string.IsNullOrWhiteSpace(plan))
            {
                ToastService.ShowToast("Clipboard is empty.", ToastType.Error);
                return;
            }
            List<Factory>? parsed = System.Text.Json.JsonSerializer.Deserialize<List<Factory>>(plan, new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });
            if (parsed == null || parsed.Count == 0)
            {
                ToastService.ShowToast("Invalid plan in clipboard.", ToastType.Error);
                return;
            }
            AppState.SetFactories(parsed);
            _factories = AppState.GetFactories();
            if (_gameData != null)
            {
                FactoryCalcService.CalculateFactories(_factories, _gameData);
            }
            _ = AppState.SaveFactoriesAsync();
            ToastService.ShowToast($"Plan pasted successfully ({parsed.Count} factories loaded).", ToastType.Success);
        }
        catch (Exception ex)
        {
            ToastService.ShowToast($"Invalid plan. Error: {ex.Message}", ToastType.Error);
        }
    }

