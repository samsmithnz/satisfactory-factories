@page "/"
@using Web.Models
@using Web.Models.Factory
@using Web.Services
@inject IAppStateService AppState
@inject GameDataService GameDataService
@inject NavigationManager NavManager
@inject LoadingService LoadingService
@inject DemoPlansService DemoPlansService
@implements IDisposable

<PageTitle>Satisfactory Factories - Production Planner</PageTitle>

<div class="planner-page">
    @if (!_isLoaded)
    {
        <div class="loading-container">
            <div class="loading-message">Loading Planner...</div>
        </div>
    }
    else
    {
        <div class="planner-container">
            <div class="two-pane-container">
                <!-- Sidebar (Desktop only) -->
                <div class="sticky-sidebar d-none d-lg-flex">
                    <div class="sidebar-content">
                        <h3>Factories</h3>
                        @if (_factories.Count == 0)
                        {
                            <p class="text-grey">No factories yet. Create one to get started!</p>
                        }
                        else
                        {
                            <ul class="factory-list">
                                @foreach (Factory factory in _factories)
                                {
                                    <li>@factory.Name</li>
                                }
                            </ul>
                        }
                        <div class="sidebar-actions mt-4">
                            <button class="btn btn-primary" @onclick="CreateFactory">
                                <i class="fas fa-plus"></i> Add Factory
                            </button>
                            <TemplatesDialog />
                            @if (_factories.Count > 0)
                            {
                                <div class="d-flex gap-2 mt-2">
                                    <button class="btn btn-secondary flex-1" @onclick="ClearAll">
                                        <i class="fas fa-trash"></i> Clear All
                                    </button>
                                    <ShareButton />
                                </div>
                            }
                        </div>
                    </div>
                </div>

                <!-- Main Content Area -->
                <div class="main-content">
                    @if (_factories.Count == 0)
                    {
                        <div class="welcome-message">
                            <h2>Welcome to Satisfactory Factories!</h2>
                            <p>This is a production planning tool for the game Satisfactory.</p>
                            <p>Get started by creating your first factory or load a demo plan.</p>
                            <div class="welcome-actions">
                                <button class="btn btn-primary btn-lg" @onclick="CreateFactory">
                                    <i class="fas fa-plus"></i> Create Your First Factory
                                </button>
                                <TemplatesDialog />
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="factories-content">
                            @foreach (Factory factory in _factories)
                            {
                                <div class="factory-card" id="factory-@factory.Id">
                                    <div class="factory-header">
                                        <h3>@factory.Name</h3>
                                        <div class="factory-actions">
                                            <button class="btn btn-sm btn-danger" @onclick="() => DeleteFactory(factory)">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </div>
                                    </div>
                                    <div class="factory-body">
                                        @if (factory.Products.Count == 0)
                                        {
                                            <p class="text-grey">No products. Add a product to this factory.</p>
                                        }
                                        @foreach (FactoryItem product in factory.Products.ToList())
                                        {
                                            <div class="product-row">
                                                <select class="form-control product-part-select"
                                                        value="@product.Id"
                                                        @onchange="(e) => OnPartSelected(product, factory, e.Value?.ToString() ?? string.Empty)">
                                                    <option value="">-- Select Part --</option>
                                                    @foreach (KeyValuePair<string, Part> partEntry in GetSortedParts())
                                                    {
                                                        <option value="@partEntry.Key">@partEntry.Value.Name</option>
                                                    }
                                                </select>
                                                @if (!string.IsNullOrEmpty(product.Id))
                                                {
                                                    <select class="form-control product-recipe-select"
                                                            value="@product.Recipe"
                                                            @onchange="(e) => OnRecipeSelected(product, factory, e.Value?.ToString() ?? string.Empty)">
                                                        @foreach (Recipe recipe in GameDataService.GetRecipesForPart(product.Id))
                                                        {
                                                            <option value="@recipe.Id">@recipe.DisplayName@(recipe.IsAlternate ? " (Alt)" : "")</option>
                                                        }
                                                    </select>
                                                    <input type="number"
                                                           class="form-control product-amount-input"
                                                           value="@product.Amount"
                                                           min="1"
                                                           @onchange="(e) => OnAmountChanged(product, factory, e.Value?.ToString() ?? string.Empty)" />
                                                }
                                                <button class="btn btn-sm btn-danger" @onclick="() => RemoveProduct(factory, product)">
                                                    <i class="fas fa-trash"></i>
                                                </button>
                                            </div>
                                        }
                                        <div class="factory-add-part mt-2">
                                            <button class="btn btn-sm btn-primary" @onclick="() => AddEmptyProduct(factory)">
                                                <i class="fas fa-plus"></i> Add Product
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            }
                            <div class="text-center mt-4">
                                <button class="btn btn-primary btn-lg" @onclick="CreateFactory">
                                    <i class="fas fa-plus"></i> Add Factory
                                </button>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
</div>

@code {
    private bool _isLoaded = false;
    private List<Factory> _factories = new List<Factory>();
    private GameData? _gameData;
    private int _nextFactoryId = 1;

    protected override async Task OnInitializedAsync()
    {
        // Subscribe to state changes
        AppState.OnChange += StateHasChanged;

        // Load game data
        _gameData = await GameDataService.LoadGameDataAsync();

        // Load factories from local storage
        await AppState.LoadFactoriesAsync();
        _factories = AppState.GetFactories();

        // Load help text preference
        // This will be used by child components in the future
        
        // Check for setupDemo query parameter
        string currentUrl = NavManager.Uri;
        if (currentUrl.Contains("setupDemo=true", StringComparison.OrdinalIgnoreCase))
        {
            // Load the demo plan automatically
            await LoadDemoPlan();
        }
        
        _isLoaded = true;
    }

    private async Task LoadDemoPlan()
    {
        Console.WriteLine("Loading demo plan from query parameter");
        
        // Load the simple demo plan using the service
        await DemoPlansService.LoadDemoPlanAsync("Simple");
        
        // Refresh factories list
        _factories = AppState.GetFactories();
        
        Console.WriteLine("Demo plan loaded successfully");
    }

    private void CreateFactory()
    {
        Factory factory = new Factory
        {
            Id = _nextFactoryId++,
            Name = $"Factory {_nextFactoryId - 1}",
            DisplayOrder = _factories.Count,
            Hidden = false,
            Products = new List<FactoryItem>(),
            Inputs = new List<FactoryInput>(),
            Parts = new Dictionary<string, PartMetrics>(),
            BuildingRequirements = new Dictionary<string, BuildingRequirement>(),
            PowerProducers = new List<FactoryPowerProducer>(),
            Power = new FactoryPower(),
            Tasks = new List<FactoryTask>(),
            Dependencies = new FactoryDependency(),
            SyncState = new Dictionary<string, FactorySyncState>(),
            SyncStatePower = new Dictionary<string, FactoryPowerSyncState>()
        };

        AppState.AddFactory(factory);
        _factories = AppState.GetFactories();
        
        // Save to local storage
        Task.Run(async () => await AppState.SaveFactoriesAsync());
    }

    private void DeleteFactory(Factory factory)
    {
        _factories.Remove(factory);
        AppState.SetFactories(_factories);
        
        // Save to local storage
        Task.Run(async () => await AppState.SaveFactoriesAsync());
    }

    private void ClearAll()
    {
        AppState.ClearFactories();
        _factories = AppState.GetFactories();
        
        // Save to local storage
        Task.Run(async () => await AppState.SaveFactoriesAsync());
    }

    private void AddEmptyProduct(Factory factory)
    {
        FactoryItem newProduct = new FactoryItem
        {
            Id = string.Empty,
            Recipe = string.Empty,
            Amount = 10,
            DisplayOrder = factory.Products.Count,
            Requirements = new Dictionary<string, RequirementAmount>(),
            BuildingRequirements = new BuildingRequirement()
        };
        factory.Products.Add(newProduct);
        _ = AppState.SaveFactoriesAsync();
    }

    private void OnPartSelected(FactoryItem product, Factory factory, string partId)
    {
        product.Id = partId;

        if (!string.IsNullOrEmpty(partId))
        {
            string defaultRecipe = GameDataService.GetDefaultRecipeForPart(partId);
            List<Recipe> recipes = GameDataService.GetRecipesForPart(partId);
            product.Recipe = !string.IsNullOrEmpty(defaultRecipe) && recipes.Count > 0
                ? defaultRecipe
                : (recipes.Count > 0 ? recipes[0].Id : string.Empty);
        }
        else
        {
            product.Recipe = string.Empty;
        }

        _ = AppState.SaveFactoriesAsync();
    }

    private void OnRecipeSelected(FactoryItem product, Factory factory, string recipeId)
    {
        product.Recipe = recipeId;
        _ = AppState.SaveFactoriesAsync();
    }

    private void OnAmountChanged(FactoryItem product, Factory factory, string amountStr)
    {
        if (double.TryParse(amountStr, out double amount) && amount > 0)
        {
            product.Amount = amount;
            _ = AppState.SaveFactoriesAsync();
        }
    }

    private void RemoveProduct(Factory factory, FactoryItem product)
    {
        factory.Products.Remove(product);
        for (int i = 0; i < factory.Products.Count; i++)
        {
            factory.Products[i].DisplayOrder = i;
        }
        _ = AppState.SaveFactoriesAsync();
    }

    private List<KeyValuePair<string, Part>> GetSortedParts()
    {
        if (_gameData == null)
        {
            return new List<KeyValuePair<string, Part>>();
        }

        return _gameData.Items.Parts
            .OrderBy(p => p.Value.Name)
            .ToList();
    }

    public void Dispose()
    {
        AppState.OnChange -= StateHasChanged;
    }
}
