@* Introduction component - Displays welcome information as a dismissable dialog *@
@inject IJSRuntime JSRuntime
@inject NavigationManager NavManager

@if (_isVisible)
{
    <div class="intro-dialog-backdrop" @onclick="Close">
        <div class="intro-dialog" @onclick:stopPropagation="true">
            <div class="intro-dialog-header">
                <h1 class="intro-dialog-title">Welcome to Satisfactory Factories!</h1>
                <h6 class="intro-dialog-subtitle">Bringing sanity to the production chain!</h6>
            </div>
            <div class="intro-dialog-body introduction-dialog">
                <div style="position: relative; width: 100%; padding-bottom: 56.25%; margin-bottom: 16px;">
                    <iframe
                        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                        allowfullscreen
                        frameborder="0"
                        style="position: absolute; top: 0; left: 0; width: 100%; height: 100%;"
                        referrerpolicy="strict-origin-when-cross-origin"
                        src="https://www.youtube.com/embed/cKuWEKwxX5c?si=mEVI0mJoiNbIwzkG"
                        title="YouTube video player">
                    </iframe>
                </div>
                <p style="font-size: 1.25rem; font-weight: 500;">Why does this tool exist?</p>
                <p>TL;DR: Create production goals for each factory, create and manage dependencies between factories, visualise the flow of items and highlight bottlenecks / gaps in supply as you scale your industrial prowess!</p>
                <p><b>Satisfactory Factories</b> helps plan and manage modular factory (or levels in mega-factories) production chains. Tracking interconnected factories and their dependencies can be overwhelming, leading to overlooked areas and bottlenecks when demands change. This tool automates calculations, ensuring proper scaling for new demands and saving time. Unlike other planners that focus on "what is needed to make X part", SF focuses on per-factory demand rather than <i>just</i> per-part demand. You can use it to determine part quantities and import requirements for future changes, maintaining the production chain and highlighting issues / bottlenecks.</p>
                <div style="padding: 16px 0; margin-bottom: 16px; border-top: 2px solid var(--border-color); border-bottom: 2px solid var(--border-color); border-radius: 4px;">
                    <p style="font-size: 1.25rem; font-weight: 500;">Enough yapping, how does it work?</p>
                    <ul style="margin-left: 16px; margin-bottom: 16px;">
                        <li style="margin-bottom: 8px;">Firstly you create a <i class="fas fa-industry" style="margin-right: 8px; width: 1em;"></i><b>Factory</b> (and give it a name!).</li>
                        <li style="margin-bottom: 8px;"><i class="fas fa-conveyor-belt-alt" style="margin-right: 8px; width: 1em;"></i><b>Products</b>: is what the factory is intending to produce (or to produce internally, these will be marked as <span class="sf-chip small" style="background-color: green; color: white;">internal</span>).</li>
                        <li style="margin-bottom: 8px;"><i class="fas fa-arrow-to-right" style="margin-right: 8px; width: 1em;"></i><b>Imports</b>: is where you are bringing in items needed for production. These use the <i class="fa fa-truck-container" style="margin-right: 8px;"></i><b>Exports</b> of other factories.</li>
                        <li style="margin-bottom: 8px;"><i class="fas fa-check" style="margin-right: 8px; width: 1em;"></i><b>Satisfaction</b>: informs you if you're short of inputs or <span class="sf-chip small" style="background-color: green; color: white;">internal</span> production to satisfy the factory's production requirements.</li>
                        <li style="margin-bottom: 8px;"><i class="fa fa-truck-container" style="margin-right: 8px;"></i><b>Exports</b>: any items after internal production is factored in, are listed as Exports ready to be shipped to other factories.</li>
                    </ul>
                    <p style="margin-bottom: 8px;">Factories that are:</p>
                    <ul style="margin-left: 16px; margin-bottom: 8px;">
                        <li style="margin-bottom: 4px;">Unsatisfied (missing imports, not enough internal production) etc</li>
                        <li style="margin-bottom: 4px;">Not producing enough to meet export demands</li>
                    </ul>
                    <p>will be marked in <span style="color: #f44336;">red</span> on both the main factory view and the list to the left.</p>
                    <p style="margin-bottom: 0;">My suggestion would be to start from "Goal first". Define a factory producing end products, then work your way back from there to the very base level products. But you can plan however you like!</p>
                </div>
                <div style="padding: 16px; margin-bottom: 16px; background-color: #37474f; border-radius: 4px;">
                    <p>
                        Please note - this project is in an <span style="color: #ff9800; font-weight: bold;">alpha</span> state, it is very hot out of the oven and there may <i>(will)</i> be some bugs. Please report any bugs to the project's <a href="https://github.com/Maelstromeous/satisfactory-factories/issues" style="color: var(--link-color);">GitHub Issues page</a> for now.
                    </p>
                    <p style="margin-bottom: 0;">Each page has a Todo section with what I plan to add. Please offer any suggestions at the GitHub link above for any improvements you'd like to see.</p>
                </div>
                <p style="margin-bottom: 0;">Happy planning! - Maelstromeous</p>
            </div>
            <div class="intro-dialog-actions">
                @if (Source == "planner")
                {
                    <button class="btn btn-primary" @onclick="Close">
                        <i class="fas fa-file mr-2"></i>Start with an empty plan
                    </button>
                    <a href="/?setupDemo=true" class="btn btn-success">
                        <i class="fas fa-list mr-2"></i>Start with a demo plan
                    </a>
                }
                @if (Source == "changelog")
                {
                    <a href="/?setupDemo=true" class="btn btn-success">
                        <i class="fas fa-list mr-2"></i>Open Demo
                    </a>
                    <button class="btn btn-primary" @onclick="Close">
                        <i class="fas fa-check mr-2"></i>Close
                    </button>
                }
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public string Source { get; set; } = "planner";

    [Parameter]
    public bool ForceShow { get; set; }

    [Parameter]
    public EventCallback OnClosed { get; set; }

    private bool _isVisible = false;
    private bool _initialized = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            string? dismissed = await JSRuntime.InvokeAsync<string?>("localStorage.getItem", "dismissed-introduction");
            bool wasDismissed = dismissed == "true";

            if (!wasDismissed || ForceShow)
            {
                _isVisible = true;
                StateHasChanged();
            }
            _initialized = true;
        }
    }

    protected override void OnParametersSet()
    {
        if (_initialized && ForceShow && !_isVisible)
        {
            _isVisible = true;
        }
    }

    private async Task Close()
    {
        _isVisible = false;
        await JSRuntime.InvokeVoidAsync("localStorage.setItem", "dismissed-introduction", "true");
        await OnClosed.InvokeAsync();
        StateHasChanged();
    }
}

