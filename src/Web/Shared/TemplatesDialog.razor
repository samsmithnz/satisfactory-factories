@using Web.Services
@inject TemplateModalService TemplateModal

<button class="btn btn-primary" @onclick="OpenModal">
    <i class="fas fa-file-medical"></i>
    Templates
</button>

@code {
    [Parameter]
    public EventCallback OnTemplateLoaded { get; set; }

    protected override void OnInitialized()
    {
        Console.WriteLine("TemplatesDialog: Initialized");
    }

    private void OpenModal()
    {
        Console.WriteLine($"TemplatesDialog: OpenModal() called — TemplateModal.IsOpen is currently {TemplateModal.IsOpen}");
        TemplateModal.Open(() => OnTemplateLoaded.InvokeAsync());
        Console.WriteLine($"TemplatesDialog: After Open() — TemplateModal.IsOpen is now {TemplateModal.IsOpen}");
    }
}
