@using Web.Services
@using Web.Models.Factory
@inject DemoPlansService DemoPlansService
@inject IToastService ToastService
@inject TemplateModalService TemplateModal
@inject IJSRuntime JSRuntime
@implements IDisposable

@if (TemplateModal.IsOpen)
{
    <div class="templates-modal-backdrop" @onclick="BackdropClicked"></div>
    <div class="modal-dialog templates-dialog" @onclick:stopPropagation="true" @onclick="DialogClicked">
        <div class="modal-header">
            <h3>Load a template plan</h3>
            <button type="button" class="close-btn" @onclick="CloseDialog" @onclick:stopPropagation="true" aria-label="Close">×</button>
        </div>
        <div class="modal-body">
            <div class="template-warning">
                <p>
                    Clicking on a button below will load a template plan into the planner.
                    <span class="warning-text">This will overwrite any existing plan WITHOUT warning.</span>
                    You may wish to save your plan first by creating a share link.
                </p>
            </div>
            @if (_errorMessage != null)
            {
                <div class="template-error">
                    <p class="text-red">@_errorMessage</p>
                </div>
            }
            @if (_isLoading)
            {
                <div class="template-loading">
                    <p><i class="fas fa-spinner fa-spin mr-2"></i>Loading @_loadingTemplateName...</p>
                </div>
            }
            <div class="templates-table">
                <table>
                    <thead>
                        <tr>
                            <th class="name-column">Name</th>
                            <th class="desc-column">Description</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (DemoPlanTemplate template in _templates)
                        {
                            DemoPlanTemplate captured = template;
                            <tr>
                                <td class="template-name-cell">
                                    <button
                                        type="button"
                                        class="btn template-btn"
                                        disabled="@_isLoading"
                                        @onclick="() => LoadTemplate(captured)"
                                        @onclick:stopPropagation="true">
                                        <i class="fas @(captured.IsDebug ? "fa-bug" : "fa-file")"></i>
                                        @captured.Name
                                    </button>
                                </td>
                                <td class="template-desc">@captured.Description</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
        <div class="modal-footer">
            <button type="button" class="btn btn-secondary" @onclick="CloseDialog" @onclick:stopPropagation="true" disabled="@_isLoading">Close</button>
        </div>
    </div>
}

@code {
    private bool _isLoading = false;
    private string _loadingTemplateName = string.Empty;
    private string? _errorMessage = null;
    private List<DemoPlanTemplate> _templates = new();
    private int _renderCount = 0;

    protected override void OnInitialized()
    {
        _templates = DemoPlansService.GetAvailableTemplates();
        TemplateModal.OnChange += OnModalStateChanged;
        Console.WriteLine($"TemplatesModal: Initialized with {_templates.Count} templates");
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        _renderCount++;
        if (TemplateModal.IsOpen)
        {
            Console.WriteLine($"TemplatesModal: Dialog rendered to DOM (render #{_renderCount}), isLoading={_isLoading}");
            await JSRuntime.InvokeVoidAsync("console.log",
                $"[JS] TemplatesModal: Dialog is in DOM (render #{_renderCount}). Bootstrap pointer-events override should be active.");
        }
    }

    public void Dispose()
    {
        TemplateModal.OnChange -= OnModalStateChanged;
    }

    private void OnModalStateChanged()
    {
        Console.WriteLine($"TemplatesModal: State changed - IsOpen={TemplateModal.IsOpen}");
        StateHasChanged();
    }

    private void BackdropClicked()
    {
        Console.WriteLine($"TemplatesModal: BACKDROP CLICKED (isLoading={_isLoading}) — this fires when click falls through dialog or user clicks outside");
        _ = JSRuntime.InvokeVoidAsync("console.warn",
            "[JS] TemplatesModal: Backdrop was clicked! If you clicked a template button and this fires, pointer-events:none is overriding the button.");
        CloseDialog();
    }

    private void DialogClicked()
    {
        Console.WriteLine($"TemplatesModal: Dialog div @onclick fired (click reached the dialog container)");
    }

    private void CloseDialog()
    {
        if (!_isLoading)
        {
            Console.WriteLine("TemplatesModal: CloseDialog called — hiding dialog");
            TemplateModal.Close();
        }
        else
        {
            Console.WriteLine("TemplatesModal: CloseDialog called but _isLoading=true — ignoring");
        }
    }

    private async Task LoadTemplate(DemoPlanTemplate template)
    {
        Console.WriteLine($"TemplatesModal: *** LoadTemplate ENTERED for '{template.Name}' ***");
        await JSRuntime.InvokeVoidAsync("console.log",
            $"[JS] TemplatesModal: LoadTemplate called for '{template.Name}'");

        _isLoading = true;
        _loadingTemplateName = template.Name;
        _errorMessage = null;
        StateHasChanged();

        try
        {
            Console.WriteLine($"TemplatesModal: Calling DemoPlansService.LoadDemoPlanAsync('{template.Name}')");

            await DemoPlansService.LoadDemoPlanAsync(template.Name);

            Console.WriteLine($"TemplatesModal: LoadDemoPlanAsync completed for '{template.Name}'");

            await TemplateModal.InvokeTemplateLoadedAsync();

            Console.WriteLine($"TemplatesModal: OnTemplateLoaded callback fired for '{template.Name}'");

            ToastService.ShowToast($"Template \"{template.Name}\" loaded successfully", ToastType.Success);

            TemplateModal.Close();
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"TemplatesModal: ERROR loading '{template.Name}': {ex.GetType().Name}: {ex.Message}");
            Console.Error.WriteLine($"TemplatesModal: Stack trace: {ex.StackTrace}");
            _errorMessage = $"Failed to load \"{template.Name}\": {ex.Message}";
            ToastService.ShowToast($"Failed to load template \"{template.Name}\"", ToastType.Error);
        }
        finally
        {
            _isLoading = false;
            _loadingTemplateName = string.Empty;
        }
    }
}
