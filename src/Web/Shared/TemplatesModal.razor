@using Web.Services
@using Web.Models.Factory
@inject DemoPlansService DemoPlansService
@inject IToastService ToastService
@inject TemplateModalService TemplateModal
@implements IDisposable

@if (TemplateModal.IsOpen)
{
    <div class="templates-modal-backdrop" @onclick="CloseDialog"></div>
    <div class="modal-dialog templates-dialog">
        <div class="modal-header">
            <h3>Load a template plan</h3>
            <button type="button" class="close-btn" @onclick="CloseDialog" aria-label="Close">×</button>
        </div>
        <div class="modal-body">
            <div class="template-warning">
                <p>
                    Clicking on a button below will load a template plan into the planner.
                    <span class="warning-text">This will overwrite any existing plan WITHOUT warning.</span>
                    You may wish to save your plan first by creating a share link.
                </p>
            </div>
            @if (_errorMessage != null)
            {
                <div class="template-error">
                    <p class="text-red">@_errorMessage</p>
                </div>
            }
            @if (_isLoading)
            {
                <div class="template-loading">
                    <p><i class="fas fa-spinner fa-spin mr-2"></i>Loading @_loadingTemplateName...</p>
                </div>
            }
            <div class="templates-table">
                <table>
                    <thead>
                        <tr>
                            <th class="name-column">Name</th>
                            <th class="desc-column">Description</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (DemoPlanTemplate template in _templates)
                        {
                            <tr>
                                <td class="template-name-cell">
                                    <button
                                        type="button"
                                        class="btn template-btn"
                                        disabled="@_isLoading"
                                        @onclick="() => LoadTemplate(template)">
                                        <i class="fas @(template.IsDebug ? "fa-bug" : "fa-file")"></i>
                                        @template.Name
                                    </button>
                                </td>
                                <td class="template-desc">@template.Description</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
        <div class="modal-footer">
            <button type="button" class="btn btn-secondary" @onclick="CloseDialog" disabled="@_isLoading">Close</button>
        </div>
    </div>
}

@code {
    private bool _isLoading = false;
    private string _loadingTemplateName = string.Empty;
    private string? _errorMessage = null;
    private List<DemoPlanTemplate> _templates = new();

    protected override void OnInitialized()
    {
        _templates = DemoPlansService.GetAvailableTemplates();
        TemplateModal.OnChange += StateHasChanged;
        Console.WriteLine($"TemplatesModal: Initialized with {_templates.Count} templates");
    }

    public void Dispose()
    {
        TemplateModal.OnChange -= StateHasChanged;
    }

    private void CloseDialog()
    {
        if (!_isLoading)
        {
            Console.WriteLine("TemplatesModal: Dialog closed");
            TemplateModal.Close();
        }
    }

    private async Task LoadTemplate(DemoPlanTemplate template)
    {
        Console.WriteLine($"TemplatesModal: LoadTemplate button clicked for '{template.Name}'");

        _isLoading = true;
        _loadingTemplateName = template.Name;
        _errorMessage = null;
        StateHasChanged();

        try
        {
            Console.WriteLine($"TemplatesModal: Starting load for '{template.Name}'");

            await DemoPlansService.LoadDemoPlanAsync(template.Name);

            Console.WriteLine($"TemplatesModal: LoadDemoPlanAsync completed for '{template.Name}'");

            await TemplateModal.InvokeTemplateLoadedAsync();

            Console.WriteLine($"TemplatesModal: Callback fired for '{template.Name}'");

            ToastService.ShowToast($"Template \"{template.Name}\" loaded successfully", ToastType.Success);

            TemplateModal.Close();
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine($"TemplatesModal: Error loading template '{template.Name}': {ex.GetType().Name}: {ex.Message}");
            Console.Error.WriteLine($"TemplatesModal: Stack trace: {ex.StackTrace}");
            _errorMessage = $"Failed to load \"{template.Name}\": {ex.Message}";
            ToastService.ShowToast($"Failed to load template \"{template.Name}\"", ToastType.Error);
        }
        finally
        {
            _isLoading = false;
            _loadingTemplateName = string.Empty;
        }
    }
}
