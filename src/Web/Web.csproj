<Project Sdk="Microsoft.NET.Sdk.BlazorWebAssembly">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <OverrideHtmlAssetPlaceholders>true</OverrideHtmlAssetPlaceholders>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.AspNetCore.Components.WebAssembly" Version="10.0.2" />
    <PackageReference Include="Microsoft.AspNetCore.Components.WebAssembly.DevServer" Version="10.0.2" PrivateAssets="all" />
  </ItemGroup>

  <Target Name="CopyGameAssets" BeforeTargets="Build"
          Condition="Exists('$(MSBuildProjectDirectory)/../../web/public/assets/game')">
    <Message Text="Copying game assets from Vue project to wwwroot..." Importance="high" />
    <ItemGroup>
      <GameAssetFiles Include="$(MSBuildProjectDirectory)/../../web/public/assets/game/**/*.*" />
    </ItemGroup>
    <Copy SourceFiles="@(GameAssetFiles)"
          DestinationFolder="$(MSBuildProjectDirectory)/wwwroot/assets/game/%(RecursiveDir)"
          SkipUnchangedFiles="true" />
  </Target>

</Project>
